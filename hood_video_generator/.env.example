OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.4-mini
OPENAI_IMAGE_MODEL=gpt-image-2
IMAGE_SIZE=1024x1024
IMAGE_QUALITY=low
IMAGE_OUTPUT_FORMAT=jpeg
IMAGE_OUTPUT_COMPRESSION=75
TOTAL_IMAGE_COUNT=10
OPENAI_TEXT_INPUT_USD_PER_1M=0.75
OPENAI_TEXT_OUTPUT_USD_PER_1M=4.50
OPENAI_IMAGE_ESTIMATED_USD_PER_IMAGE=0.011
STORY_MIN_CHARS=1050
STORY_TARGET_CHARS=1150
STORY_MAX_CHARS=1250
VIDEO_MIN_DURATION_SECONDS=64
VIDEO_MAX_DURATION_SECONDS=70
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
OUTPUT_DIR=output
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30

# Stimme: 1.0 normal, 1.08 schneller, 0.92 langsamer
VOICE_SPEED=1.3

# Untertitel
SUBTITLE_MODE=grouped_emphasis
SUBTITLE_FONT_SIZE=86
SUBTITLE_Y_FROM_BOTTOM=360
SUBTITLE_MIN_WORDS=2
SUBTITLE_MAX_WORDS=4

# Cover/Intro: nutzt assets/intro/intro.png
COVER_ENABLED=true
COVER_DURATION=1.5
COVER_TITLE_TEXT=Hood Storys aus\ndeutschen Städten

# Abschlussfolie: nutzt assets/outro/outro.png
OUTRO_ENABLED=true
OUTRO_DURATION=3.0
STORY_END_PADDING_SECONDS=0.35
AUDIO_BOUNDARY_FADE_SECONDS=0.04
OUTRO_TEXT=Folge für weitere\ndeutsche Hoodstorys\n\nWelche Stadt als\nnächstes ???\n\nSchreibt es\nin die\nKommentare !

# Optionale Sounds. Lege deine Dateien genau dort ab.
COVER_TRANSITION_SOUND=assets/sfx/cover_transition.mp3
COVER_TRANSITION_VOLUME=0.316
COVER_TRANSITION_RELOAD_VOLUME=0.45
COVER_TRANSITION_SPLIT_SECONDS=3.25
COVER_TRANSITION_SOUND_START_SECONDS=1.55
COVER_TRANSITION_FIRST_SPEED=2.5
COVER_TRANSITION_SECOND_SPEED=0.65
COVER_TRANSITION_SYNC_ADVANCE_SECONDS=0.10
BACKGROUND_MUSIC=assets/music/background.mp3
BACKGROUND_MUSIC_VOLUME=0.032

# Sounddesign: lokale Dateien in assets/sounds/
SOUND_DESIGN_ENABLED=true
SOUND_ASSETS_DIR=assets/sounds
USE_SIGNATURE_HIT=true
USE_TRANSITION_WHOOSH=true
USE_LOW_BOOM_ON_TWISTS=true
USE_GLITCH_ON_DIGITAL_MOMENTS=true
USE_RISER_BEFORE_TWIST=false
USE_AMBIENT_LOOP=true
USE_RELOAD_SOUND=false
AUTO_CONVERT_MP4_SOUNDS=true
CONVERTED_SOUND_OUTPUT_DIR=assets/sounds/converted
SIGNATURE_HIT_VOLUME=0.25
TRANSITION_WHOOSH_VOLUME=0.18
LOW_BOOM_VOLUME=0.22
GLITCH_VOLUME=0.16
RISER_VOLUME=0.12
AMBIENT_VOLUME=0.06
COVER_TITLE_FONT_SIZE=92
COVER_EPISODE_FONT_SIZE=88
OUTRO_FONT_SIZE=92

# Bildbewegung und Uebergaenge
TRANSITION_DURATION=0.7
KEN_BURNS_ZOOM=0.06
KEN_BURNS_DRIFT=24
